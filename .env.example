# Firebase Configuration (obtener desde Firebase Console)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Microsoft Azure AD — App Registration (portal.azure.com)
# Tipo de cuenta soportado: multitenant (organizacional + personal)
# Redirect URI SPA: http://localhost:5173 (dev) | URL Firebase Hosting (prod)
# Permisos Graph API delegados: User.Read, Calendars.Read, Mail.Read, offline_access
VITE_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_MSAL_REDIRECT_URI=http://localhost:5173

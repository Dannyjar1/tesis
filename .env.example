# Firebase Configuration (obtener desde Firebase Console)
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Microsoft Azure AD — App Registration (portal.azure.com)
# Tipo de cuenta: single-tenant (solo cuentas @uide.edu.ec)
# Plataforma: SPA. Redirect URIs registrados:
#   http://localhost:5173 (dev)
#   https://uide-distributivo-loja.web.app (prod)
#   https://uide-distributivo-loja.firebaseapp.com (prod / handler Firebase Auth)
# Permisos Graph delegados: User.Read, Calendars.Read, Mail.ReadWrite,
#   offline_access, openid, profile, email
VITE_MSAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Directory (tenant) ID que entrega TI. Sin él, MSAL cae a 'common' (dev).
VITE_MSAL_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# Claude API — interpretación IA de correos → tareas To Do (iaCorreoService)
# PENDIENTE: crear API key en console.anthropic.com. Sin ella se usa el
# intérprete heurístico local (modo mock).
VITE_CLAUDE_API_KEY=placeholder

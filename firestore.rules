rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Modelo de seguridad (PROJECT.md MOD-01) ──────────────────────────────
    // Identidad: Firebase Authentication con proveedor Microsoft Azure AD.
    // Acceso a datos: solo sesiones autenticadas cuyo email pertenece al
    // dominio institucional @uide.edu.ec (request.auth.token.email).
    // Autorización por rol (admin/director/docente…) se aplica además en la
    // capa de la aplicación (RoleGuard + rutas protegidas, modelo roles[]).
    //
    // PENDIENTE (al conectar Azure AD real): cuando /usuarios quede keyed por
    // el UID de Firebase Auth, activar el modelo completo por rol documentado
    // en PROJECT.md §9 (getRoles() con 'admin' in roles, alcance por carrera_id).
    // Hoy los UID de la app son del seed y no coinciden con request.auth.uid,
    // por lo que las funciones de rol en reglas bloquearían el sistema.

    function esInstitucional() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('(?i).*@uide[.]edu[.]ec');
    }

    // ── Colecciones del sistema ───────────────────────────────────────────────
    match /usuarios/{uid} {
      allow read, write: if esInstitucional();
    }
    match /carreras/{carreraId} {
      allow read, write: if esInstitucional();
    }
    match /docentes/{uid} {
      allow read, write: if esInstitucional();
    }
    match /periodos_academicos/{periodoId} {
      allow read, write: if esInstitucional();
    }
    match /distributivos/{docId} {
      // RF-022/RN: los distributivos se archivan, nunca se eliminan (trazabilidad CACES)
      allow read, create, update: if esInstitucional();
      allow delete: if false;
    }
    match /actividades/{actId} {
      allow read, write: if esInstitucional();
    }
    match /horario_semanal/{bloqueId} {
      allow read, write: if esInstitucional();
    }
    match /clasificaciones_ia/{cId} {
      allow read, write: if esInstitucional();
    }
    match /feedback/{fbId} {
      allow read, write: if esInstitucional();
    }
    match /notificaciones/{notifId} {
      allow read, write: if esInstitucional();
    }
    match /reportes/{repId} {
      allow read, write: if esInstitucional();
    }
    match /auditoria/{logId} {
      // RN-009: la auditoría es inmutable — solo se crean registros, jamás se
      // modifican ni eliminan (evidencia para acreditación CACES)
      allow read, create: if esInstitucional();
      allow update, delete: if false;
    }
    match /configuracion/{configId} {
      allow read, write: if esInstitucional();
    }

    // Colecciones fuera de alcance del MVP (RESTRUCTURE §5) — NO se crean y
    // quedan denegadas por la regla por defecto: eventos_calendario, tareas_todo,
    // matriz_productividad, planes_mejora, oficios, roles_definicion.

    // Por defecto, todo lo demás queda bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Variables de entorno de Cloud Functions — copiar a functions/.env (NO commitear)
#
# Twilio WhatsApp (RF-038):
# - TWILIO_ACCOUNT_SID y TWILIO_AUTH_TOKEN van como SECRETS en producción:
#     firebase functions:secrets:set TWILIO_ACCOUNT_SID
#     firebase functions:secrets:set TWILIO_AUTH_TOKEN
#   En functions/.env solo se ponen para el emulador local.
# - TWILIO_WHATSAPP_FROM: número emisor. El default es el sandbox de Twilio
#   (desarrollo, gratis). En producción se cambia por el número aprobado.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Clasificación IA (MOD-04):
# CLASIFICADOR_MODO=heuristica (default) | beto (requiere modelo fine-tuned)
# CLASIFICADOR_MODO=heuristica
# RUTA_MODELO_BETO=/tmp/modelos/beto-distributivo
